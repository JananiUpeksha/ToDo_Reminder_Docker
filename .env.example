# Postgres credentials (used by db, api, and worker services)
POSTGRES_USER=todo_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=todo_db

# Mailtrap SMTP credentials (used by worker service for sending reminder emails)
# Get these from your Mailtrap sandbox inbox -> SMTP Settings
MAILTRAP_USER=your_mailtrap_username
MAILTRAP_PASSWORD=your_mailtrap_password
